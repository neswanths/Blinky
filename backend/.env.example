DATABASE_URL=postgresql://postgres:yourpassword@db.yourproject.supabase.co:5432/postgres

# Google OAuth — Get from console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# Set to your deployed API URL on Fly.io
GOOGLE_REDIRECT_URI=https://your-app.fly.dev/auth/callback

# Set to your Vercel frontend URL
FRONTEND_URL=https://blinky.vercel.app

# Generate with: openssl rand -hex 32
BLINKY_SECRET_KEY=generate-a-long-random-secret-here
